{
  "openapi": "3.1.0",
  "info": {
    "title": "SMB AI Workflow Actions - Prompt Generator",
    "version": "1.0.0",
    "description": "No-auth, stateless, planning-oriented Action."
  },
  "servers": [
    {
      "url": "https://YOUR-VERCEL-DOMAIN.vercel.app",
      "description": "Replace with your deployed Vercel base URL."
    }
  ],
  "paths": {
    "/api/prompt-generator": {
      "post": {
        "operationId": "generatePrompt",
        "summary": "Execute prompt-generator",
        "description": "No-auth, stateless, planning-oriented Action.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "agentRole": {
                    "type": "string"
                  },
                  "workflowContext": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "agentRole": "example",
                "workflowContext": "example"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "systemPrompt": {
                      "type": "string"
                    },
                    "guidelines": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "example": {
                  "systemPrompt": "example",
                  "guidelines": []
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}